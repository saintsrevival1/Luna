	local Dragging
	local DragInput
	local DragStart
	local StartPosition

	local function Lerp(a, b, m)
		return a + (b - a) * m
	end

	local LastMousePosition
	local LastGoalPosition

	local DragSpeed = 25

	local function Update(DeltaTime)
		if not StartPosition then return end
		if not Dragging and LastGoalPosition then
			Background.Position = UDim2.new(StartPosition.X.Scale, Lerp(Background.Position.X.Offset, LastGoalPosition.X.Offset, DeltaTime * DragSpeed), StartPosition.Y.Scale, Lerp(Background.Position.Y.Offset, LastGoalPosition.Y.Offset, DeltaTime * DragSpeed))
			return
		end

		local Delta = (LastMousePosition - UserInputService:GetMouseLocation())
		local XGoal = (StartPosition.X.Offset - Delta.X)
		local YGoal = (StartPosition.Y.Offset - Delta.Y)

		LastGoalPosition = UDim2.new(StartPosition.X.Scale, XGoal, StartPosition.Y.Scale, YGoal)
		Background.Position = UDim2.new(StartPosition.X.Scale, Lerp(Background.Position.X.Offset, XGoal, DeltaTime * DragSpeed), StartPosition.Y.Scale, Lerp(Background.Position.Y.Offset, YGoal, DeltaTime * DragSpeed))
	end

	DragButton.MouseButton1Down:Connect(function()
		Dragging = true
		DragStart = UserInputService:GetMouseLocation()
		StartPosition = Background.Position
		LastMousePosition = UserInputService:GetMouseLocation()
	end)

	UserInputService.InputEnded:Connect(function(Input)
		if Input.UserInputType == Enum.UserInputType.MouseButton1 then
			Dragging = false
		end
	end)

	Background.InputChanged:Connect(function(Input)
		if Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch then
