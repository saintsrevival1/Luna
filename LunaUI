						SliderBox.Position = UDim2.new((Value - SliderOptions.Min) / (SliderOptions.Max - SliderOptions.Min), 0, 0.5, 0)
						SliderBar.Size = UDim2.new((Value - SliderOptions.Min) / (SliderOptions.Max - SliderOptions.Min), 0, 1, 0)

						local Value = RoundNumber(SliderOptions.Min + (SliderOptions.Max - SliderOptions.Min) * Percentage, SliderOptions.Rounding)
						SliderValue.Text = tostring(Value)
						SliderOptions.Callback(Value)
					end
				end)

				SliderValue.FocusLost:Connect(function(EnterPressed)
					if EnterPressed then
						local Text = SliderValue.Text

						if tonumber(Text) then
							local Value = math.clamp(RoundNumber(tonumber(Text), SliderOptions.Rounding), SliderOptions.Min, SliderOptions.Max)
							SliderBar.Size = UDim2.new((Value - SliderOptions.Min) / (SliderOptions.Max - SliderOptions.Min), 0, 1, 0)
							SliderBox.Position = UDim2.new(math.clamp((Value - SliderOptions.Min) / (SliderOptions.Max - SliderOptions.Min), 0, 1), 0, 0.5, 0)
							SliderValue.Text = tostring(Value)
							SliderOptions.Callback(Value)
						end
					end
				end)
			end

